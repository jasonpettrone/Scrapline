<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <MaxCpuCount>1</MaxCpuCount>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <TestSessionTimeout>180000</TestSessionTimeout>
    <TreatNoTestsAsError>true</TreatNoTestsAsError>
  </RunConfiguration>

  <!-- GODOT_BIN is supplied by the environment (local gate + CI), not hardcoded here,
       so this stays cross-platform. -->
  <GdUnit4>
    <!-- Run the GdUnit4-hosted Godot headless so it needs no display on Linux CI. -->
    <Parameters>--headless</Parameters>
    <DisplayName>FullyQualifiedName</DisplayName>
  </GdUnit4>
</RunSettings>
