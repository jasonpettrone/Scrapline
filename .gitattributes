# Normalize line endings: LF in the repo so Linux CI never sees CRLF.
# Windows checkouts still build fine; .NET and Godot are LF-tolerant.
* text=auto eol=lf

# Binary asset types Godot/.-NET produce or consume — never normalize these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.gif  binary
*.webp binary
*.wav  binary
*.ogg  binary
*.mp3  binary
*.ttf  binary
*.otf  binary
*.exe  binary
*.dll  binary
*.pck  binary
*.zip  binary
